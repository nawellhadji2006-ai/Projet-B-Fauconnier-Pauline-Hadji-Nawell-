void lesparkings(FILE *f, parkings P1[]){

    int i = 0;
    fscanf(f,"%*[^\n]\n"); // Pour passer la premiere ligne qui est le nom de colonnes
    while (fscanf(f,"%49[^;];%49[^;];%49[^;];%49[^;];%49[^;];%d;%d;%49[^;];%49[^\n]\n",
                  P1[i].Identifiant,
                  P1[i].Nom,
                  P1[i].Adresse,
                  P1[i].Ville,
                  P1[i].Etat,
                  &P1[i].Places_dispo,
                  &P1[i].Capacite_max,
                  P1[i].Date_de_mise_a_jour,
                  P1[i].Affichage_panneaux)== 9){
            i++;
    }
}

