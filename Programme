void sortieParking (suiviClient SC[]){
    char id[50];
    int h1, m1;
    int h2, m2;
    printf("Entrez l'heure d' arrivee (hh mm): ");
    scanf("%d %d", &h1, &m1);

    printf("Entrez l'heure de depart (hh mm): ");
    scanf("%d %d", &h2, &m2);
    int time1_minutes = h1 * 60 + m1;
    int time2_minutes = h2 * 60 + m2;
    if (time2_minutes < time1_minutes) {
            time2_minutes += 24 * 60;
    }
    int diff_minutes = time2_minutes - time1_minutes;


    char plaque[10];
    printf("Entrer un identifiant\n");
    scanf("%s", id);
    printf("Entrer votre plaque\n");
    scanf("%s",plaque);

    float prix = diff_minutes*0.03; // Nous avons prit comme convention que les parkings sont à 3 centimes la minutes
    printf(" Le parking : %s, Plaque d'immatriculation : %s, A payer : %f\n", id, plaque, prix);
    suivi_Client(SC, plaque, prix, h1, m1, h2, m2, id);
}


void suivi_Client (suiviClient SC[], char Plaque[], float montant_paye,
                   int h1,int m1,int h2,int m2, char id_parking[]){

    static int i = 0;

    strcpy(SC[i].Plaque, Plaque);
    SC[i].montant_paye = montant_paye;
    sprintf(SC[i].heure_entree, "%02d:%02d", h1, m1);
    sprintf(SC[i].heure_sortie, "%02d:%02d", h2, m2);
    strcpy(SC[i].id_parking, id_parking);

    i++;
}


