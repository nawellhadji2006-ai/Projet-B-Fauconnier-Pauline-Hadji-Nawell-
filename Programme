        strcpy(P2[i].Identifiant, P1[i].Identifiant);
        strcpy(P2[i].Nom, P1[i].Nom);
        strcpy(P2[i].Adresse, P1[i].Adresse);
        strcpy(P2[i].Ville, P1[i].Ville);
        strcpy(P2[i].Etat, P1[i].Etat);
